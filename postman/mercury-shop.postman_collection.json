{
  "info": {
    "name": "Mercury Shop",
    "description": "Fluxo ponta a ponta da API Mercury Shop. Rode em ordem: login admin -> criar produto -> registrar/verificar/login cliente -> carrinho -> checkout -> pagar. Tokens e ids são salvos automaticamente nas variáveis da coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminEmail", "value": "admin@mercury.dev" },
    { "key": "adminPassword", "value": "Adm1n!Passw0rd" },
    { "key": "customerPassword", "value": "Str0ng!Passw0rd" },
    { "key": "customerEmail", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "verifyToken", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login admin (dev)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('200', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('adminToken', pm.response.json().accessToken);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] }
          }
        },
        {
          "name": "Registrar cliente",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "pm.collectionVariables.set('customerEmail', 'cliente_' + Date.now() + '@example.com');"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.to.have.status(201));",
              "console.log('Cliente:', pm.collectionVariables.get('customerEmail'));",
              "console.log('Pegue o token de verificação no LOG da app: [EMAIL] ... payload=<TOKEN> e cole na variável verifyToken.');"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"fullName\": \"Cliente Teste\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "register"] }
          }
        },
        {
          "name": "Verificar e-mail (cole o token do log em verifyToken)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/auth/verify?token={{verifyToken}}",
              "host": ["{{baseUrl}}"], "path": ["v1", "auth", "verify"],
              "query": [ { "key": "token", "value": "{{verifyToken}}" } ]
            }
          }
        },
        {
          "name": "Login cliente",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('200', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('accessToken', pm.response.json().accessToken);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] }
          }
        },
        {
          "name": "Meu perfil (/me)",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/users/me", "host": ["{{baseUrl}}"], "path": ["v1", "users", "me"] }
          }
        }
      ]
    },
    {
      "name": "2. Catálogo (admin)",
      "item": [
        {
          "name": "Criar categoria",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('categoryId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{adminToken}}", "type": "string" } ] },
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Eletrônicos {{$timestamp}}\",\n  \"description\": \"Categoria de teste\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/categories", "host": ["{{baseUrl}}"], "path": ["v1", "categories"] }
          }
        },
        {
          "name": "Criar produto",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('productId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{adminToken}}", "type": "string" } ] },
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mouse sem fio\",\n  \"description\": \"2.4GHz\",\n  \"price\": 99.90,\n  \"stockQuantity\": 50,\n  \"categoryId\": \"{{categoryId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/products", "host": ["{{baseUrl}}"], "path": ["v1", "products"] }
          }
        },
        {
          "name": "Listar produtos (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/products?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["v1", "products"],
              "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ]
            }
          }
        },
        {
          "name": "Ver produto (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["v1", "products", "{{productId}}"] }
          }
        }
      ]
    },
    {
      "name": "3. Compra (cliente)",
      "item": [
        {
          "name": "Adicionar ao carrinho",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}" },
            "url": { "raw": "{{baseUrl}}/v1/cart/items", "host": ["{{baseUrl}}"], "path": ["v1", "cart", "items"] }
          }
        },
        {
          "name": "Ver carrinho",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/cart", "host": ["{{baseUrl}}"], "path": ["v1", "cart"] }
          }
        },
        {
          "name": "Checkout (Idempotency-Key)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('orderId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "header": [ { "key": "Idempotency-Key", "value": "{{$guid}}" } ],
            "url": { "raw": "{{baseUrl}}/v1/orders", "host": ["{{baseUrl}}"], "path": ["v1", "orders"] }
          }
        },
        {
          "name": "Pagar pedido",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/orders/{{orderId}}/pay", "host": ["{{baseUrl}}"], "path": ["v1", "orders", "{{orderId}}", "pay"] }
          }
        },
        {
          "name": "Meus pedidos",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/orders", "host": ["{{baseUrl}}"], "path": ["v1", "orders"] }
          }
        }
      ]
    }
  ]
}
