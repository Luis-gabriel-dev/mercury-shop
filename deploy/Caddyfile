{
	# E-mail para o ACME (Let's Encrypt). Ajuste para o seu.
	email admin@adastratech.dev
}

# --- Produção: HTTPS automático + HSTS ---
mercury-shop.adastratech.dev {
	encode gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

	# Não expõe o Actuator/métricas publicamente (Prometheus faz scrape pela rede interna).
	handle /actuator/* {
		respond 404
	}

	# Balanceia entre as réplicas da API (DNS do compose resolve para vários IPs).
	# Sobrescreve o X-Forwarded-For com o IP real do cliente (descarta o que vier forjado),
	# para o rate limiting da API confiar no endereço resolvido.
	reverse_proxy api:8080 {
		header_up X-Forwarded-For {remote_host}
		lb_policy least_conn
		# Health checks ativos + passivos: só encaminha para réplicas saudáveis, então recriar uma
		# réplica por vez (rolling) mantém o serviço no ar — deploy sem downtime.
		health_uri /actuator/health
		health_interval 10s
		health_timeout 3s
		fail_duration 15s
	}
}

# --- Teste local: TLS interno autoassinado em https://localhost ---
localhost {
	tls internal
	handle /actuator/* {
		respond 404
	}
	reverse_proxy api:8080 {
		header_up X-Forwarded-For {remote_host}
	}
}
