# Stack de produção (deploy/docker-compose.yml). Copie para deploy/.env e ajuste.
# NUNCA commitar o .env com valores reais.

POSTGRES_DB=mercury_shop_db
POSTGRES_USER=mercury
POSTGRES_PASSWORD=troque-este-valor

RABBITMQ_USER=mercury
RABBITMQ_PASSWORD=troque-este-valor

# Chaves RSA do JWT em PEM (uma linha, com \n). Gere com openssl (ver README "Como rodar").
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

CORS_ALLOWED_ORIGINS=https://mercury-shop.adastratech.dev

GRAFANA_PASSWORD=troque-este-valor
