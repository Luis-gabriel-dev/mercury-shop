{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "title": "Mercury Shop — Negócio",
  "tags": ["mercury-shop", "business"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GMV acumulado",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyBRL" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(mercury_orders_gmv_total)",
          "legendFormat": "GMV"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ticket médio (AOV)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyBRL" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(mercury_orders_gmv_total) / clamp_min(sum(mercury_payments_approved_total), 1)",
          "legendFormat": "AOV"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Conversão (pagos / criados)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(mercury_payments_approved_total) / clamp_min(sum(mercury_orders_placed_total), 1)",
          "legendFormat": "conversão"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GMV por minuto",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "currencyBRL" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(mercury_orders_gmv_total[5m])) * 60",
          "legendFormat": "GMV/min"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pedidos e pagamentos por minuto",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "opm" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(mercury_orders_placed_total[5m])) * 60",
          "legendFormat": "pedidos/min"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(mercury_payments_approved_total[5m])) * 60",
          "legendFormat": "pagamentos/min"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Perdas (cancelados / expirados)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(mercury_orders_cancelled_total)",
          "legendFormat": "cancelados"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(mercury_orders_expired_total)",
          "legendFormat": "expirados (não pagos)"
        }
      ]
    }
  ]
}