# Mercury Shop — variáveis de ambiente (copie para .env e ajuste).
# NUNCA commitar o .env com valores reais (está no .gitignore).

# --- Conexão da aplicação com o Postgres ---
DB_URL=jdbc:postgresql://localhost:5432/mercury_shop_db
DB_USER=mercury
DB_PASSWORD=troque-este-valor

# --- Container Postgres (usado pelo compose.yaml) ---
POSTGRES_DB=mercury_shop_db
POSTGRES_USER=mercury
POSTGRES_PASSWORD=troque-este-valor
