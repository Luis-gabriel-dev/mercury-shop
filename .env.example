# Mercury Shop — variáveis de ambiente (copie para .env e ajuste).
# NUNCA commitar o .env com valores reais (está no .gitignore).

# --- Conexão da aplicação com o Postgres ---
DB_URL=jdbc:postgresql://localhost:5432/mercury_shop_db
DB_USER=mercury
DB_PASSWORD=troque-este-valor

# --- Container Postgres (usado pelo compose.yaml) ---
POSTGRES_DB=mercury_shop_db
POSTGRES_USER=mercury
POSTGRES_PASSWORD=troque-este-valor

# --- Redis (refresh tokens, bloqueio de login, rate limiting) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (RSA) ---
# Em dev/test pode deixar vazio: a aplicação gera um par RSA efêmero no boot.
# Em prod, gere um par e injete o PEM (uma linha, com \n) ou aponte para arquivo montado:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-private.pem
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- CORS: allowlist explícita de origens (nunca '*' com credenciais) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
